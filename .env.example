# ============================================================
# HOTEL MANAGEMENT SYSTEM – BACKEND ENVIRONMENT CONFIG
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked  ← CHANGE THIS
# 3. Never commit .env to source control
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5000
APP_NAME=HotelMS Pro

# ── Database (MySQL) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password   # ← CHANGE THIS
DB_NAME=hotel_management_db
DB_POOL_MIN=2
DB_POOL_MAX=10
# Set to +00:00 if your MySQL server runs in UTC
DB_TIMEZONE=+05:30

# ── JWT ─────────────────────────────────────────────────────
# Minimum 32 random characters.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS  # ← CHANGE THIS
JWT_EXPIRES_IN=7d

JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_LONG_RANDOM_STRING  # ← CHANGE THIS
JWT_REFRESH_EXPIRES_IN=30d

# ── Email / SMTP ────────────────────────────────────────────
# In NODE_ENV=development every e-mail is only logged to the console.
# Set these for production use.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false             # true = TLS on port 465
SMTP_USER=your_email@gmail.com        # ← CHANGE THIS
SMTP_PASS=your_gmail_app_password     # ← CHANGE THIS  (use an App Password)
EMAIL_FROM="HotelMS Pro <noreply@hotelms.com>"

# ── Frontend (for CORS + reset-password links) ───────────────
FRONTEND_URL=http://localhost:3000

# ── File uploads ────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880          # bytes → 5 MB

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW=15           # minutes
RATE_LIMIT_MAX=100             # requests per window per IP

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info                 # error | warn | info | http | debug
LOG_DIR=./logs
